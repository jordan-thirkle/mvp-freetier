---
import '../styles/global.css';
import data from '../../public/tools.json';

const tools = data.categories;
const totalTools = tools.reduce((s, c) => s + c.items.length, 0);

const title = 'FreeTier — The Free SaaS Stack';
const desc = `Discover free tiers, generous plans, and cheap alternatives for indie SaaS builders. Hosting, databases, auth, email, analytics, AI, LLMs — ${totalTools} tools across ${tools.length} categories.`;
const colorMap: Record<string, string> = {
  emerald: 'border-accent-secondary/20 text-accent-secondary bg-accent-secondary/10',
  violet: 'border-accent-primary/20 text-accent-primary bg-accent-primary/10',
  amber: 'border-warning/20 text-warning bg-warning/10',
  blue: 'border-sky-400/20 text-sky-400 bg-sky-400/10',
};
const categoryColors: Record<string, string> = {
  hosting: 'emerald', databases: 'violet', auth: 'amber', 'email-communication': 'blue',
  analytics: 'emerald', 'ai-llms': 'violet', payments: 'emerald', monitoring: 'amber', cms: 'violet',
};
const catEmojis: Record<string, string> = {
  hosting: '☁️', databases: '🗄️', auth: '🔐', 'email-communication': '✉️',
  analytics: '📊', 'ai-llms': '🤖', payments: '💳', monitoring: '🛡️', cms: '📝',
};
const repoUrl = 'https://github.com/jordan-thirkle/freetier-data';
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={desc} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={desc} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <title>{title}</title>
  <script type="application/ld+json" is:inline>
    {JSON.stringify({"@context":"https://schema.org","@type":"WebApplication","name":"FreeTier","url":"https://freetier.byjtt.com","description":`${totalTools} tools across ${tools.length} categories.`,"applicationCategory":"DeveloperApplication","operatingSystem":"All"})}
  </script>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='6' fill='%236366f1'/><text x='16' y='22' text-anchor='middle' font-size='18' font-weight='bold' fill='white'>FT</text></svg>" />
</head>

<body class="min-h-screen flex flex-col">
  <!-- Navigation -->
  <nav class="mx-auto max-w-6xl w-full px-6 py-4 flex items-center justify-between border-b border-border">
    <a href="/" class="flex items-center gap-3 group">
      <div class="w-8 h-8 rounded-lg bg-accent-primary/10 flex items-center justify-center text-accent-primary font-bold text-sm group-hover:scale-105 transition-transform">FT</div>
      <span class="text-sm font-medium text-primary">FreeTier</span>
      <span class="text-[9px] font-mono uppercase tracking-wider text-tertiary bg-surface border border-border px-1.5 py-0.5 rounded">Beta</span>
    </a>
    <div class="flex items-center gap-4 text-xs">
      <a href="https://byjtt.com" target="_blank" rel="noopener" class="text-tertiary hover:text-primary transition-colors font-mono uppercase tracking-[0.1em]">ByJTT</a>
      <a href={repoUrl} target="_blank" rel="noopener" class="text-tertiary hover:text-primary transition-colors font-mono uppercase tracking-[0.1em]">Open Data</a>
    </div>
  </nav>

  <main class="flex-grow">
    <!-- Hero -->
    <section class="mx-auto max-w-3xl px-6 pt-16 pb-8 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent-secondary/5 border border-accent-secondary/20 text-xs font-mono text-accent-secondary mb-6">
        {totalTools}+ tools · 9 categories · Free forever
      </div>
      <h1 class="text-white text-4xl md:text-6xl font-display font-light leading-tight tracking-tight mb-4">
        The <span class="bg-gradient-to-r from-accent-primary to-accent-secondary bg-clip-text text-transparent">Free Stack</span>
      </h1>
      <p class="text-lg text-tertiary max-w-xl mx-auto mb-8 leading-relaxed">
        Build your entire SaaS on free tiers — or as close as possible. {totalTools} tools across {tools.length} categories.
      </p>

      <!-- Filters -->
      <div class="flex flex-wrap items-center justify-center gap-1.5 mb-6">
        <button data-cat="all" class="tag active">All</button>
        {tools.map(c => <button data-cat={c.id} class="tag">{catEmojis[c.id] || ''} {c.name}</button>)}
      </div>

      <!-- Search -->
      <div class="flex items-center justify-center gap-3 max-w-md mx-auto">
        <div class="relative flex-1">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-quaternary pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input id="search-input" type="search" placeholder="Search {totalTools} tools..." class="w-full pl-9 pr-3 py-2.5 text-sm bg-surface border border-border rounded-lg text-primary placeholder:text-quaternary outline-none focus:border-accent-primary/50 transition-all" />
        </div>
        <select id="sort-select" class="bg-surface border border-border rounded-lg px-3 py-2.5 text-sm text-tertiary outline-none focus:border-accent-primary/50">
          <option value="name">A-Z</option>
        </select>
      </div>
      <p class="text-[10px] font-mono text-quaternary mt-2" id="result-count">{totalTools} tools</p>
    </section>

    <!-- Tool Grid -->
    <section id="app-root" class="mx-auto max-w-6xl px-6 pb-12 space-y-10">
      {tools.map(c => {
        const dotColor = c.id === 'hosting' ? '#6366f1' : c.id === 'databases' ? '#34d399' : c.id === 'auth' ? '#f59e0b' : c.id === 'ai-llms' ? '#a78bfa' : '#6366f1';
        const items = c.items.map(t => {
          const href = t.refUrl || t.url;
          return (
            <a href={href} target="_blank" rel="nofollow sponsored" data-tool data-name={t.name} data-desc={t.desc} data-category={c.id} class="card group">
              <div class="flex items-start justify-between mb-2">
                <span class="text-primary font-medium text-sm flex items-center gap-1.5 group-hover:text-accent-primary transition-colors">
                  {t.name}
                  {t.refUrl ? <span class="text-[9px] font-mono uppercase tracking-wider text-accent-secondary bg-accent-secondary/10 px-1.5 py-0.5 rounded">ref</span> : null}
                </span>
                <span class={`tag text-[8px] whitespace-nowrap ${colorMap[t.color] || ''}`}>{t.free}</span>
              </div>
              <p class="text-xs text-tertiary leading-relaxed">{t.desc}</p>
            </a>
          );
        });
        return (
          <div data-section={c.id}>
            <h2 class="text-primary text-sm font-medium mb-3 flex items-center gap-2">
              <span class="inline-block w-2 h-2 rounded-full" style={`background-color:${dotColor}`} />
              {catEmojis[c.id] || ''} {c.name}
            </h2>
            <div data-grid class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
              {items}
            </div>
          </div>
        );
      })}
    </section>

    <!-- Community -->
    <section class="mx-auto max-w-3xl px-6 pb-16 text-center">
      <div class="card border-accent-primary/10 bg-accent-primary/5 py-8 px-6">
        <h3 class="text-primary text-sm font-medium mb-2">Suggest a Tool</h3>
        <p class="text-xs text-tertiary mb-4 max-w-md mx-auto">Know a great free tier we missed? The data is open-source — submit a PR or open an issue on GitHub.</p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href={`${repoUrl}/issues/new?template=suggest-tool.md`} target="_blank" rel="noopener" class="btn-primary">Open an Issue</a>
          <a href={`${repoUrl}/tree/main/tools.json`} target="_blank" rel="noopener" class="btn-secondary">Edit tools.json</a>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="mx-auto max-w-6xl w-full px-6 pb-12 pt-8 border-t border-border text-center">
    <div class="flex flex-wrap items-center justify-center gap-4 text-xs text-tertiary font-mono uppercase tracking-[0.1em] mb-4">
      <a href="https://byjtt.com" class="hover:text-primary transition-colors">ByJTT</a>
      <span class="text-quaternary">·</span>
      <a href="https://byjtt.com/blog" class="hover:text-primary transition-colors">Blog</a>
      <span class="text-quaternary">·</span>
      <a href={repoUrl} target="_blank" rel="noopener" class="hover:text-primary transition-colors">Data Repo</a>
    </div>
    <p class="text-[9px] font-mono text-quaternary uppercase tracking-[0.2em]">FreeTier · {totalTools} tools across {tools.length} categories · Links may be affiliate referrals</p>
  </footer>

  <script type="module">
    const app = document.getElementById('app-root');
    if (!app) return;

    const cards = Array.from(app.querySelectorAll('[data-tool]'));
    const search = document.getElementById('search-input') as HTMLInputElement | null;
    const sortEl = document.getElementById('sort-select') as HTMLSelectElement | null;
    const cats = document.querySelectorAll('[data-cat]');
    let activeCat = 'all';

    function render() {
      const q = search?.value.toLowerCase() || '';
      cats.forEach(c => c.classList.toggle('active', c.getAttribute('data-cat') === activeCat));

      const groups = new Map<string, Element[]>();
      cards.forEach(c => {
        const name = c.getAttribute('data-name') || '';
        const desc = c.getAttribute('data-desc') || '';
        const cat = c.getAttribute('data-category') || '';
        const matches = q === '' || name.toLowerCase().includes(q) || desc.toLowerCase().includes(q);
        const catMatch = activeCat === 'all' || cat === activeCat;
        const show = matches && catMatch;
        c.classList.toggle('hidden', !show);
        if (show) {
          const g = groups.get(cat) || [];
          g.push(c);
          groups.set(cat, g);
        }
      });

      const sections = app.querySelectorAll('[data-section]');
      sections.forEach(s => {
        const id = s.getAttribute('data-section');
        const items = groups.get(id || '') || [];
        const isVisible = (q === '' && (activeCat === 'all' || activeCat === id)) || items.length > 0;
        s.classList.toggle('hidden', !isVisible);
        if (isVisible) {
          const grid = s.querySelector('[data-grid]');
          if (grid && sortEl) {
            grid.innerHTML = '';
            const sorted = [...items].sort((a, b) =>
              (a.getAttribute('data-name') || '').toLowerCase().localeCompare((b.getAttribute('data-name') || '').toLowerCase())
            );
            sorted.forEach(c => grid.appendChild(c));
          }
        }
      });

      const count = document.getElementById('result-count');
      const total = cards.filter(c => !c.classList.contains('hidden')).length;
      if (count) count.textContent = `${total} tool${total !== 1 ? 's' : ''}`;
    }

    search?.addEventListener('input', render);
    sortEl?.addEventListener('change', render);
    cats.forEach(c => c.addEventListener('click', () => { activeCat = c.getAttribute('data-cat') || 'all'; render(); }));
    render();
  </script>
</body>
</html>
